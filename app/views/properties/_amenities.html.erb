<%# app/views/properties/_amenities.html.erb %>

<% preview = property.amenities_for_preview %>
<% total_available = property.property_amenities.size %>

<div>
    <section class="pt-10 mt-4 border-t border-gray-200" aria-labelledby="amenities-heading">
    <h2 id="amenities-heading" class="text-xl font-medium text-gray-900">
        What this place offers
    </h2>

    <% if preview.empty? %>
        <p class="mt-4 text-gray-500">No amenities listed yet.</p>
    <% else %>
        <ul class="grid grid-cols-1 gap-y-3 mt-4 sm:grid-cols-2" role="list">
        <% preview.each do |pa| %>
            <li class="flex items-center gap-x-3 <%= 'opacity-40' if !pa.available? %>">
            <span class="<%= 'line-through' if !pa.available? %> shrink-0 text-gray-600">
                <%= amenity_icon(pa.slug) %>
            </span>
            <span class="text-sm text-gray-800 <%= 'line-through' if !pa.available? %>">
                <%= pa.name %>
            </span>
            <% if pa.extra_cost? %>
                <span class="text-xs text-gray-500">(extra cost)</span>
            <% end %>
            </li>
        <% end %>
        </ul>

        <% if total_available > Property::AMENITIES_PREVIEW_LIMIT %>
        <div
            data-controller="modal"
            class="mt-6"
        >
            <button
            type="button"
            data-action="modal#open"
            class="inline-flex items-center py-2 px-4 text-sm font-medium text-gray-900 bg-white rounded-lg border border-gray-900 hover:bg-gray-50 focus:ring-2 focus:ring-gray-900 focus:ring-offset-2 focus:outline-none"
            >
            Show all <%= total_available %> amenities
            </button>

            <%= render "properties/amenities_modal", property: property %>
        </div>
        <% end %>
    <% end %>
    </section>
</div>    